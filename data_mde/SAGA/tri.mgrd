  <HISTORY saga-version="9.10.2">
    <TOOL library="ta_morphometry" id="16" name="Terrain Ruggedness Index (TRI)">
      <OPTION type="grid_system" id="PARAMETERS_GRID_SYSTEM" name="Grid System">
        <CELLSIZE>0.0002694945852359</CELLSIZE>
        <XMIN>-74.21840453207702</XMIN>
